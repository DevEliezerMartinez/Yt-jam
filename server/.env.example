# Copia este archivo como .env y llena los valores

# ID de tu playlist "Oficina" en YouTube
# Lo encuentras en la URL: youtube.com/playlist?list=ESTE_ES_EL_ID
YT_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta que la extensión manda en cada request
# Ponla también en la extensión (popup.js → SECRET_KEY)
SECRET_KEY=oficina-2024-secreto
